# demo | claude
AI_PROVIDER=demo

# Required only when AI_PROVIDER=claude
CLAUDE_API_KEY=
CLAUDE_MODEL=

# Optional Google Docs export integration
# anyone_with_link | share_with_email | private
# Service account mode is best for shared-drive or Workspace setups
# Use the full service-account private_key value, not private_key_id
GOOGLE_DOCS_SHARE_MODE=anyone_with_link
GOOGLE_DOCS_SHARE_EMAIL=
GOOGLE_DOCS_CLIENT_EMAIL=
GOOGLE_DOCS_PRIVATE_KEY=
