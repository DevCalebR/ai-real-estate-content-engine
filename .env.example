# demo | claude
AI_PROVIDER=demo

# Required only when AI_PROVIDER=claude
CLAUDE_API_KEY=
CLAUDE_MODEL=

# Optional Google Docs export integration
# Google OAuth is the recommended auth model for personal Drive exports
# anyone_with_link | share_with_email | private
GOOGLE_DOCS_SHARE_MODE=anyone_with_link
GOOGLE_DOCS_SHARE_EMAIL=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/api/auth/google/callback
